{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": ".index/contracts/repository-index-entry-v1.json",
  "contract": "repository-index-entry-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "entry_id",
    "title",
    "kind",
    "summary",
    "responsibility",
    "boundary_paths",
    "important_files",
    "inputs",
    "outputs",
    "external_dependencies",
    "public_interfaces",
    "review_hints"
  ],
  "properties": {
    "contract": {
      "const": "repository-index-entry-v1"
    },
    "entry_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "enum": [
        "module",
        "subsystem",
        "contract",
        "workflow",
        "service",
        "tooling",
        "document"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "responsibility": {
      "type": "string",
      "minLength": 1
    },
    "boundary_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "important_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/io_ref"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/io_ref"
      }
    },
    "external_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "kind",
          "notes"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "public_interfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "kind",
          "location",
          "notes"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "location": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "review_hints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "io_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
